# MySQL container environment for local development
# Edit these values as needed before running install.sh

CONTAINER_NAME=mysql-server
PORT=3306
PASS=root
VOLUME_NAME=mysql_data
VOLUME_PATH=$HOME/.container_deploy/database/relational/mysql
IMAGE=docker.io/mysql:8.0

# Optional initial DB/user (leave empty if not needed)
MYSQL_DATABASE=mydb
MYSQL_USER=myuser
MYSQL_PASSWORD=mypass